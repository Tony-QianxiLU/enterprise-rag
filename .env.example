# Copy to .env and fill in real values for local development.
# Every field has a working local default -- the app runs fully offline
# without any of these set.

# LLM / embeddings (optional -- falls back to deterministic local providers)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# Storage
DATABASE_URL=sqlite:///./data/enterprise_rag.db
CHROMA_PERSIST_DIR=data/chroma

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# API
API_BASE_URL=http://localhost:8000
